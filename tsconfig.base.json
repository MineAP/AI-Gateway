{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ai-gateway/gateway": ["apps/gateway/src"],
      "@ai-gateway/compatibility": ["packages/compatibility/src"],
      "@ai-gateway/provider": ["packages/provider/src"],
      "@ai-gateway/protocol": ["packages/protocol/src"],
      "@ai-gateway/config": ["packages/config/src"],
      "@ai-gateway/shared": ["packages/shared/src"]
    }
  }
}
